---
import Layout from '../../layouts/Layout.astro';
import SkinDrawer from '../../components/SkinDrawer.astro';
---

<Layout title="3D / Motion - Coming Soon">
  <style is:global>
    body { background-color: #0D1117; }
  </style>

  <main class="min-h-screen flex flex-col items-center justify-center gap-6 p-8 text-center">
    <p class="text-slate-500 text-xs tracking-widest uppercase">3D / Motion Skin</p>
    <h1 class="text-5xl font-bold text-white">Coming Soon</h1>
    <a href="/" class="text-slate-400 hover:text-white text-sm transition-colors">Back to Matrix</a>
  </main>

  <SkinDrawer current="3D / Motion" />
</Layout>
