---
import Layout from '../../layouts/Layout.astro';
import SkinDrawer from '../../components/SkinDrawer.astro';
---

<Layout title="Light - Coming Soon">
  <main class="min-h-screen bg-white flex flex-col items-center justify-center gap-6 p-8 text-center">
    <p class="text-slate-400 text-xs tracking-widest uppercase">Light Skin</p>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-900">
      Coming Soon
    </h1>
    <p class="text-slate-400 max-w-sm leading-relaxed">
      This skin is parked. The active experience is Matrix.
    </p>
    <a href="/" class="px-6 py-3 border border-slate-200 text-slate-500 hover:text-slate-900 hover:border-emerald-500/50 font-medium rounded-lg transition-colors">
      Back to Matrix
    </a>
  </main>

  <SkinDrawer current="Light" />
</Layout>
