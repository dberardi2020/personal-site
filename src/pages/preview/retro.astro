---
import Layout from '../../layouts/Layout.astro';
import SkinDrawer from '../../components/SkinDrawer.astro';
---

<Layout title="Retro - Coming Soon">
  <style is:global>
    body { background-color: #0d0d2b; color: #e8e8f0; font-family: 'Courier New', monospace; }
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.12) 2px, rgba(0,0,0,0.12) 4px);
      pointer-events: none;
      z-index: 9999;
    }
    .pixel-box {
      border: 2px solid #ff2d78;
      box-shadow: 0 0 0 2px #0d0d2b, 0 0 0 4px #ff2d78;
    }
    @keyframes blink { 50% { opacity: 0; } }
    .blink { animation: blink 1s step-end infinite; }
  </style>

  <main class="min-h-screen flex flex-col items-center justify-center gap-8 p-8 text-center">
    <div class="pixel-box px-6 py-2 text-[#00e5ff] text-xs tracking-widest uppercase">
      Retro Skin
    </div>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tight" style="color:#ff2d78; text-shadow: 0 0 20px #ff2d78, 0 0 40px rgba(255,45,120,0.4);">
      INSERT COIN<span class="blink">_</span>
    </h1>
    <p class="text-[#00e5ff] text-sm tracking-wider uppercase max-w-sm leading-relaxed">
      This skin is under construction.<br />The Matrix skin is live now.
    </p>
    <a href="/" class="pixel-box px-6 py-3 text-[#ff2d78] text-sm tracking-widest uppercase hover:bg-[#ff2d78]/10 transition-colors">
      &lt; Back to Matrix
    </a>
  </main>

  <SkinDrawer current="Retro" />
</Layout>
