---
import Layout from '../../layouts/Layout.astro';
import SkinDrawer from '../../components/SkinDrawer.astro';
import { personal, about, skills, experience, education, gameDev, hobbies } from '../../data/content';
---

<Layout>
  <style>
    body { background-color: #FAF7F2; color: #292524; }
  </style>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#FAF7F2]/90 backdrop-blur-sm border-b border-stone-200">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="font-serif font-bold text-lg text-stone-800">{personal.initials}</span>
      <div class="flex gap-6 text-sm text-stone-400">
        <a href="#about-earthy" class="hover:text-stone-800 transition-colors">About</a>
        <a href="#work-earthy" class="hover:text-stone-800 transition-colors">Work</a>
        <a href="#gamedev-earthy" class="hover:text-stone-800 transition-colors">Game Dev</a>
        <a href="#hobbies-earthy" class="hover:text-stone-800 transition-colors">Hobbies</a>
        <a href="#contact-earthy" class="hover:text-stone-800 transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-6 pt-14">
    <div class="max-w-5xl mx-auto w-full">
      <p class="text-amber-700 text-sm tracking-widest uppercase mb-6 font-medium">Hey, I'm</p>
      <h1 class="text-6xl md:text-8xl font-serif font-bold tracking-tight text-stone-900 mb-6 leading-tight">
        Dimitri<br />Berardi
      </h1>
      <p class="text-xl text-stone-500 mb-12 max-w-xl leading-relaxed font-light">{personal.tagline}</p>
      <div class="flex gap-4 flex-wrap">
        <a href="#work-earthy" class="px-7 py-3 bg-stone-800 hover:bg-stone-700 text-stone-100 font-medium rounded-sm transition-colors">
          View My Work
        </a>
        <a href="#contact-earthy" class="px-7 py-3 border border-stone-300 hover:border-stone-500 text-stone-600 hover:text-stone-900 font-medium rounded-sm transition-colors">
          Get In Touch
        </a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about-earthy" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-16">
        <h2 class="font-serif text-3xl font-bold text-stone-800">About Me</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-16">
        <div>
          <h3 class="text-amber-700 text-xs tracking-widest uppercase mb-6 font-medium">Who I Am</h3>
          {about.who.map(p => <p class="text-stone-600 leading-loose mb-4 font-light">{p}</p>)}
        </div>
        <div>
          <h3 class="text-amber-700 text-xs tracking-widest uppercase mb-6 font-medium">My Mission</h3>
          {about.mission.map(p => <p class="text-stone-600 leading-loose mb-4 font-light">{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="py-24 px-6 bg-stone-100/60">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-16">
        <h2 class="font-serif text-3xl font-bold text-stone-800">Skills</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-12">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="text-amber-700 text-xs tracking-widest uppercase mb-4 font-medium">
              {category.replace(/([A-Z])/g, ' $1').trim()}
            </h3>
            <p class="text-stone-600 font-light leading-relaxed">
              {items.join(' · ')}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="work-earthy" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-16">
        <h2 class="font-serif text-3xl font-bold text-stone-800">Experience</h2>
      </div>
      <div class="space-y-14">
        {experience.map(job => (
          <div class="grid md:grid-cols-[200px_1fr] gap-8">
            <div>
              <p class="text-stone-400 text-sm font-light">{job.period}</p>
            </div>
            <div>
              <h3 class="font-serif text-xl font-bold text-stone-800 mb-1">{job.title}</h3>
              <p class={`text-sm ${job.promotion ? 'mb-1' : 'mb-4'} font-medium ${job.current ? 'text-amber-700' : 'text-stone-400'}`}>
                {job.company} · {job.location}
              </p>
              {job.promotion && <p class="text-xs text-stone-400 font-light mb-4">{job.promotion}</p>}
              <ul class="text-stone-500 text-sm space-y-2 font-light leading-relaxed">
                {job.bullets.map(b => <li class="flex gap-2"><span class="text-amber-600 mt-1">–</span><span>{b}</span></li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="py-24 px-6 bg-stone-100/60">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-16">
        <h2 class="font-serif text-3xl font-bold text-stone-800">Education</h2>
      </div>
      <div class="grid md:grid-cols-[200px_1fr] gap-8">
        <p class="text-stone-400 text-sm font-light">Graduated {education.graduated}</p>
        <div>
          <h3 class="font-serif text-xl font-bold text-stone-800 mb-1">{education.school}</h3>
          <p class="text-amber-700 text-sm font-medium mb-1">{education.degree} · GPA {education.gpa}</p>
          <p class="text-stone-400 text-sm font-light">{education.minors}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- GAME DEV -->
  <section id="gamedev-earthy" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-8">
        <h2 class="font-serif text-3xl font-bold text-stone-800">Game Dev</h2>
      </div>
      <p class="text-stone-500 mb-16 max-w-xl font-light">{gameDev.description}</p>
      <div class="grid md:grid-cols-2 gap-8">
        {gameDev.games.map(game => (
          <div class="border border-stone-200 rounded-sm p-6 bg-white/60">
            <span class="text-xs text-amber-700 tracking-widest uppercase font-medium">{game.status}</span>
            <h3 class="font-serif text-xl font-bold text-stone-800 mt-2 mb-3">{game.title}</h3>
            <p class="text-stone-500 text-sm leading-relaxed font-light">{game.description}</p>
          </div>
        ))}
        <div class="border border-dashed border-stone-200 rounded-sm p-6 flex flex-col justify-center">
          <span class="text-xs text-stone-300 tracking-widest uppercase">Coming Soon</span>
          <h3 class="font-serif text-xl text-stone-300 mt-2">Next Title</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- HOBBIES -->
  <section id="hobbies-earthy" class="py-24 px-6 bg-stone-100/60">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-8">
        <h2 class="font-serif text-3xl font-bold text-stone-800">Hobbies & Interests</h2>
      </div>
      <p class="text-stone-400 mb-16 font-light">When I'm not at a keyboard.</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {hobbies.map(({ label, icon }) => (
          <div class="flex items-center gap-4 py-4 border-b border-stone-200">
            <span class="text-xl">{icon}</span>
            <span class="text-stone-600 font-medium">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact-earthy" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="border-t border-stone-300 pt-12 mb-8">
        <h2 class="font-serif text-3xl font-bold text-stone-800">Get In Touch</h2>
      </div>
      <p class="text-stone-500 mb-12 max-w-xl font-light">Whether it's a project, a job, or just a conversation — I'm open to it.</p>
      <div class="flex gap-4 flex-wrap">
        <a href={`mailto:${personal.email}`} class="px-7 py-3 bg-stone-800 hover:bg-stone-700 text-stone-100 font-medium rounded-sm transition-colors">Email Me</a>
        <a href={personal.github} target="_blank" rel="noopener noreferrer" class="px-7 py-3 border border-stone-300 hover:border-stone-500 text-stone-600 hover:text-stone-900 font-medium rounded-sm transition-colors">GitHub</a>
        <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="px-7 py-3 border border-stone-300 hover:border-stone-500 text-stone-600 hover:text-stone-900 font-medium rounded-sm transition-colors">LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-8 px-6 border-t border-stone-200">
    <div class="max-w-5xl mx-auto flex items-center justify-between text-sm text-stone-400 font-light">
      <span>© {personal.copyright}</span>
      <span>Built with Astro + Tailwind</span>
    </div>
  </footer>

  <SkinDrawer current="Earthy" />
</Layout>
