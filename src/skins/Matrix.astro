---
import Layout from '../layouts/Layout.astro';
import SkinDrawer from '../components/SkinDrawer.astro';
import PromotionGroup from '../components/PromotionGroup.astro';
import { personal, about, skills, experience, education, gameDev, hobbies } from '../data/content';
---

<Layout>
  <style is:global>
    body { background-color: #000; color: #00ff41; font-family: 'Courier New', Courier, monospace; }

    .m-bright  { color: #39ff14; text-shadow: 0 0 8px #39ff14; }
    .m-text    { color: #00ff41; }
    .m-mid     { color: #00cc33; }
    .m-dim     { color: #003b00; }

    .m-heading {
      color: #00ff41;
      font-family: monospace;
      text-shadow: 0 0 10px #00ff41, 0 0 20px rgba(0,255,65,0.4);
    }

    .m-card         { border: 1px solid #003b00; background: #000; }
    .m-card-active  { border: 1px solid #00ff41; background: #000; box-shadow: 0 0 10px rgba(0,255,65,0.1), inset 0 0 10px rgba(0,255,65,0.03); }

    .m-btn-primary {
      background: #00ff41;
      color: #000;
      font-family: monospace;
      font-weight: bold;
      padding: 10px 24px;
      display: inline-block;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.8rem;
      transition: box-shadow 0.2s;
    }
    .m-btn-primary:hover { box-shadow: 0 0 20px #00ff41, 0 0 40px rgba(0,255,65,0.3); }

    .m-btn-secondary {
      background: transparent;
      color: #00ff41;
      font-family: monospace;
      font-weight: bold;
      padding: 10px 24px;
      display: inline-block;
      border: 1px solid #00ff41;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.8rem;
      transition: all 0.2s;
    }
    .m-btn-secondary:hover { background: rgba(0,255,65,0.07); box-shadow: 0 0 15px rgba(0,255,65,0.2); }

    .m-tag {
      border: 1px solid #003b00;
      color: #00cc33;
      font-size: 0.7rem;
      padding: 3px 8px;
      background: rgba(0,255,65,0.04);
    }

    .cursor {
      display: inline-block;
      width: 8px;
      height: 14px;
      background: #00ff41;
      vertical-align: middle;
      animation: cur 1s step-end infinite;
      box-shadow: 0 0 6px #00ff41;
    }
    @keyframes cur { 50% { opacity: 0; } }

    #matrix-rain { position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1; opacity: 0.06; }
  </style>

  <canvas id="matrix-rain"></canvas>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-[#003b00]" style="background: rgba(0,0,0,0.92);">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="font-mono font-bold text-sm m-bright">{personal.initials}<span class="cursor"></span></span>
      <div class="flex gap-6 text-xs font-mono m-mid">
        <a href="#about-matrix" class="hover:text-[#00ff41] transition-colors">./about</a>
        <a href="#work-matrix" class="hover:text-[#00ff41] transition-colors">./work</a>
        <a href="#gamedev-matrix" class="hover:text-[#00ff41] transition-colors">./games</a>
        <a href="#contact-matrix" class="hover:text-[#00ff41] transition-colors">./contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-screen flex flex-col justify-center px-6 pt-14">
    <div class="max-w-5xl mx-auto w-full">
      <p class="font-mono text-xs m-dim mb-1">$ whoami</p>
      <h1 class="m-heading text-6xl md:text-8xl font-bold tracking-tight leading-none mb-1">
        Dimitri<br />Berardi
      </h1>
      <p class="font-mono text-xs m-dim mb-2 mt-4">$ cat tagline.txt</p>
      <p class="m-mid font-mono text-sm mb-10 max-w-xl leading-relaxed">{personal.tagline}</p>
      <div class="flex gap-4 flex-wrap">
        <a href="#work-matrix" class="m-btn-primary">./view-work</a>
        <a href="#contact-matrix" class="m-btn-secondary">./contact</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about-matrix" class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ cat about.txt</p>
      <h2 class="m-heading text-3xl font-bold mb-16">// About Me</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="m-card-active p-8">
          <p class="font-mono text-xs m-dim mb-4">// who_i_am.md</p>
          {about.who.map(p => <p class="m-mid font-mono text-sm leading-relaxed mb-4">{p}</p>)}
        </div>
        <div class="m-card p-8">
          <p class="font-mono text-xs m-dim mb-4">// mission.md</p>
          {about.mission.map(p => <p class="m-mid font-mono text-sm leading-relaxed mb-4">{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ ls ./skills/</p>
      <h2 class="m-heading text-3xl font-bold mb-16">// Skills</h2>
      <div class="grid md:grid-cols-2 gap-6">
        {Object.entries(skills).map(([category, items]) => (
          <div class="m-card p-6">
            <p class="font-mono text-xs m-dim mb-3">// {category.replace(/([A-Z])/g, '_$1').trim().toLowerCase().replace(/^_/,'')}</p>
            <div class="flex flex-wrap gap-2">
              {items.map(s => <span class="m-tag">{s}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="work-matrix" class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ cat experience.log</p>
      <h2 class="m-heading text-3xl font-bold mb-16">// Experience</h2>
      <div class="space-y-6">
        {experience.map(entry => (
          entry.type === 'promotion' ? (
            <div class={`p-6 ${entry.current ? 'm-card-active' : 'm-card'}`}>
              <PromotionGroup
                group={entry}
                titleClass={`text-sm font-mono font-bold uppercase tracking-wider ${entry.current ? 'm-bright' : 'm-text'}`}
                companyClass={entry.current ? 'm-text font-mono text-xs' : 'm-dim font-mono text-xs'}
                periodClass="text-xs font-mono m-dim"
                bulletClass="m-mid font-mono text-xs"
                prevRoleClass="m-dim font-mono text-xs uppercase tracking-wider"
                connectorLineClass="border-[#003b00]"
                badgeClass="font-mono m-dim border border-[#003b00]"
              />
            </div>
          ) : (
            <div class={`p-6 ${entry.current ? 'm-card-active' : 'm-card'}`}>
              <div class="flex items-start justify-between gap-4 flex-wrap mb-2">
                <h3 class={`text-sm font-mono font-bold uppercase tracking-wider ${entry.current ? 'm-bright' : 'm-text'}`}>{entry.title}</h3>
                <span class="text-xs font-mono m-dim border border-[#003b00] px-2 py-0.5">{entry.period}</span>
              </div>
              <p class={`text-xs font-mono mb-4 ${entry.current ? 'm-text' : 'm-dim'}`}>
                {entry.company} :: {entry.location}
              </p>
              <ul class="m-mid text-xs font-mono space-y-2 leading-relaxed">
                {entry.bullets.map(b => <li class="flex gap-2"><span class="m-dim">-&gt;</span><span>{b}</span></li>)}
              </ul>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ cat education.txt</p>
      <h2 class="m-heading text-3xl font-bold mb-16">// Education</h2>
      <div class="m-card-active p-6">
        <div class="flex items-start justify-between gap-4 flex-wrap mb-2">
          <h3 class="text-sm font-mono font-bold m-bright uppercase">{education.school}</h3>
          <span class="text-xs font-mono m-dim border border-[#003b00] px-2 py-0.5">GRAD {education.graduated}</span>
        </div>
        <p class="text-xs font-mono m-text mb-1">{education.degree} :: GPA {education.gpa}</p>
        <p class="m-dim text-xs font-mono">{education.minors}</p>
      </div>
    </div>
  </section>

  <!-- GAME DEV -->
  <section id="gamedev-matrix" class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ ls ./projects/games/</p>
      <h2 class="m-heading text-3xl font-bold mb-4">// Game Dev</h2>
      <p class="m-dim font-mono text-sm mb-16 max-w-xl">{gameDev.description}</p>
      <div class="grid md:grid-cols-2 gap-6">
        {gameDev.games.map(game => (
          <div class="m-card-active p-6">
            <span class="text-xs font-mono m-dim">[{game.status}]</span>
            <h3 class="text-base font-mono font-bold m-bright mt-2 mb-3">{game.title}</h3>
            <p class="m-mid text-xs font-mono leading-relaxed">{game.description}</p>
          </div>
        ))}
        <div class="m-card p-6 flex flex-col justify-center opacity-25">
          <span class="text-xs font-mono m-dim">[pending]</span>
          <h3 class="text-base font-mono font-bold m-dim mt-2">next_title<span class="cursor"></span></h3>
        </div>
      </div>
    </div>
  </section>

  <!-- HOBBIES -->
  <section id="hobbies-matrix" class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ cat hobbies.txt</p>
      <h2 class="m-heading text-3xl font-bold mb-4">// Hobbies</h2>
      <p class="m-dim font-mono text-xs mb-16">// when not at a keyboard</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {hobbies.map(({ label, icon }) => (
          <div class="m-card p-6 flex items-center gap-4">
            <span class="text-xl">{icon}</span>
            <span class="m-mid font-mono text-xs uppercase tracking-wider">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact-matrix" class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="font-mono text-xs m-dim mb-1">$ ./send_message.sh</p>
      <h2 class="m-heading text-3xl font-bold mb-4">// Get In Touch</h2>
      <p class="m-dim font-mono text-sm mb-12 max-w-xl">// project, job, or just a conversation - I'm open to it</p>
      <div class="flex gap-4 flex-wrap">
        <a href={`mailto:${personal.email}`} class="m-btn-primary">./email</a>
        <a href={personal.github} target="_blank" rel="noopener noreferrer" class="m-btn-secondary">./github</a>
        <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="m-btn-secondary">./linkedin</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-8 px-6 border-t border-[#003b00]">
    <div class="max-w-5xl mx-auto flex items-center justify-between text-xs font-mono m-dim">
      <span>// © {personal.copyright}</span>
      <span>built_with: [astro, tailwind]</span>
    </div>
  </footer>

  <SkinDrawer current="Matrix" />

  <script>
    const canvas = document.getElementById('matrix-rain') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    function resize() {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノ@#$%&';
    const size = 14;
    let cols = Math.floor(canvas.width / size);
    let drops: number[] = Array(cols).fill(1);

    function draw() {
      ctx.fillStyle = 'rgba(0,0,0,0.05)';
      ctx.fillRect(0, 0, canvas.width, canvas.height);
      ctx.fillStyle = '#00ff41';
      ctx.font = `${size}px monospace`;

      for (let i = 0; i < drops.length; i++) {
        const ch = chars[Math.floor(Math.random() * chars.length)];
        ctx.fillText(ch, i * size, drops[i] * size);
        if (drops[i] * size > canvas.height && Math.random() > 0.975) drops[i] = 0;
        drops[i]++;
      }
    }

    setInterval(draw, 50);
  </script>
</Layout>
