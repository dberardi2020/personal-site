---
import Layout from '../layouts/Layout.astro';
import SkinDrawer from '../components/SkinDrawer.astro';
import PromotionGroup from '../components/PromotionGroup.astro';
import { personal, about, skills, experience, education, gameDev, hobbies } from '../data/content';
---

<Layout>
  <style is:global>
    body { background-color: #ffffff; color: #0f172a; }
  </style>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-sm border-b border-slate-200">
    <div class="max-w-5xl mx-auto px-6 h-14 flex items-center justify-between">
      <span class="font-semibold tracking-tight text-emerald-600">{personal.initials}</span>
      <div class="flex gap-6 text-sm text-slate-500">
        <a href="#about-light" class="hover:text-slate-900 transition-colors">About</a>
        <a href="#work-light" class="hover:text-slate-900 transition-colors">Work</a>
        <a href="#gamedev-light" class="hover:text-slate-900 transition-colors">Game Dev</a>
        <a href="#hobbies-light" class="hover:text-slate-900 transition-colors">Hobbies</a>
        <a href="#contact-light" class="hover:text-slate-900 transition-colors">Contact</a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="min-h-dvh flex flex-col justify-center px-6 pt-14">
    <div class="max-w-5xl mx-auto w-full">
      <p class="text-emerald-600 text-sm font-medium tracking-widest uppercase mb-4">Hey, I'm</p>
      <h1 class="text-6xl md:text-8xl font-bold tracking-tight text-slate-900 mb-6">
        Dimitri<br />Berardi
      </h1>
      <p class="text-xl md:text-2xl text-slate-500 mb-10 max-w-xl">{personal.tagline}</p>
      <div class="flex gap-4 flex-wrap">
        <a href="#work-light" class="px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors">View My Work</a>
        <a href="#contact-light" class="px-6 py-3 border border-slate-300 hover:border-slate-400 text-slate-600 hover:text-slate-900 font-semibold rounded-lg transition-colors">Get In Touch</a>
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about-light" class="py-10 md:py-16 px-6 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-16 text-slate-900">About Me</h2>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="text-emerald-600 text-sm font-medium tracking-widest uppercase mb-4">Who I Am</h3>
          {about.who.map(p => <p class="text-slate-600 leading-relaxed mb-4">{p}</p>)}
        </div>
        <div>
          <h3 class="text-emerald-600 text-sm font-medium tracking-widest uppercase mb-4">My Mission</h3>
          {about.mission.map(p => <p class="text-slate-600 leading-relaxed mb-4">{p}</p>)}
        </div>
      </div>
    </div>
  </section>

  <!-- SKILLS -->
  <section class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-16 text-slate-900">Skills</h2>
      <div class="grid md:grid-cols-2 gap-8">
        {Object.entries(skills).map(([category, items]) => (
          <div>
            <h3 class="text-emerald-600 text-sm font-medium tracking-widest uppercase mb-4">
              {category.replace(/([A-Z])/g, ' $1').trim()}
            </h3>
            <div class="flex flex-wrap gap-2">
              {items.map(s => (
                <span class="px-3 py-1 bg-slate-100 text-slate-700 rounded-md text-sm border border-slate-200">{s}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section id="work-light" class="py-10 md:py-16 px-6 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-16 text-slate-900">Experience</h2>
      <div class="space-y-10">
        {experience.map(entry => (
          entry.type === 'promotion' ? (
            <div class={`border-l-2 pl-6 ${entry.current ? 'border-emerald-500' : 'border-slate-200'}`}>
              <PromotionGroup
                group={entry}
                titleClass="text-lg font-semibold text-slate-900"
                companyClass={entry.current ? 'text-emerald-600' : 'text-slate-500'}
                periodClass="text-sm text-slate-400"
                bulletClass="text-slate-500"
                prevRoleClass="text-slate-500"
                connectorLineClass="border-slate-200"
                badgeClass="text-slate-400 border border-slate-200"
              />
            </div>
          ) : (
            <div class={`border-l-2 pl-6 ${entry.current ? 'border-emerald-500' : 'border-slate-200'}`}>
              <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
                <h3 class="text-lg font-semibold text-slate-900">{entry.title}</h3>
                <span class="text-sm text-slate-400">{entry.period}</span>
              </div>
              <p class={`text-sm mb-3 ${entry.current ? 'text-emerald-600' : 'text-slate-500'}`}>
                {entry.company} · {entry.location}
              </p>
              <ul class="text-slate-500 text-sm space-y-2 list-disc list-inside leading-relaxed">
                {entry.bullets.map(b => <li>{b}</li>)}
              </ul>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- EDUCATION -->
  <section class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-16 text-slate-900">Education</h2>
      <div class="border-l-2 border-emerald-500 pl-6">
        <div class="flex items-start justify-between gap-4 flex-wrap mb-1">
          <h3 class="text-lg font-semibold text-slate-900">{education.school}</h3>
          <span class="text-sm text-slate-400">Graduated {education.graduated}</span>
        </div>
        <p class="text-emerald-600 text-sm mb-1">{education.degree} · GPA {education.gpa}</p>
        <p class="text-slate-500 text-sm">{education.minors}</p>
      </div>
    </div>
  </section>

  <!-- GAME DEV -->
  <section id="gamedev-light" class="py-10 md:py-16 px-6 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-4 text-slate-900">Game Dev</h2>
      <p class="text-slate-500 mb-16 max-w-xl">{gameDev.description}</p>
      <div class="grid md:grid-cols-2 gap-6">
        {gameDev.games.map(game => (
          <div class="bg-white rounded-xl p-6 border border-slate-200 shadow-sm">
            <span class="text-xs font-medium text-emerald-600 tracking-widest uppercase">{game.status}</span>
            <h3 class="text-xl font-semibold text-slate-900 mt-2 mb-3">{game.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{game.description}</p>
          </div>
        ))}
        <div class="bg-white rounded-xl p-6 border border-slate-200 border-dashed flex flex-col justify-center">
          <span class="text-xs font-medium text-slate-300 tracking-widest uppercase">Coming Soon</span>
          <h3 class="text-xl font-semibold text-slate-200 mt-2">Next Title</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- HOBBIES -->
  <section id="hobbies-light" class="py-10 md:py-16 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-4 text-slate-900">Hobbies & Interests</h2>
      <p class="text-slate-500 mb-16 max-w-xl">When I'm not at a keyboard.</p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {hobbies.map(({ label, icon }) => (
          <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 flex items-center gap-4">
            <span class="text-2xl">{icon}</span>
            <span class="text-slate-700 font-medium">{label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section id="contact-light" class="py-10 md:py-16 px-6 bg-slate-50">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold mb-4 text-slate-900">Get In Touch</h2>
      <p class="text-slate-500 mb-12 max-w-xl">Whether it's a project, a job, or just a conversation - I'm open to it.</p>
      <div class="flex gap-4 flex-wrap">
        <a href={`mailto:${personal.email}`} class="px-6 py-3 bg-emerald-500 hover:bg-emerald-600 text-white font-semibold rounded-lg transition-colors">Email Me</a>
        <a href={personal.github} target="_blank" rel="noopener noreferrer" class="px-6 py-3 border border-slate-300 hover:border-slate-400 text-slate-600 hover:text-slate-900 font-semibold rounded-lg transition-colors">GitHub</a>
        <a href={personal.linkedin} target="_blank" rel="noopener noreferrer" class="px-6 py-3 border border-slate-300 hover:border-slate-400 text-slate-600 hover:text-slate-900 font-semibold rounded-lg transition-colors">LinkedIn</a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="py-8 px-6 border-t border-slate-200">
    <div class="max-w-5xl mx-auto flex items-center justify-between text-sm text-slate-400">
      <span>© {personal.copyright}</span>
      <span>Built with Astro + Tailwind</span>
    </div>
  </footer>

  <SkinDrawer current="Light" />

</Layout>
